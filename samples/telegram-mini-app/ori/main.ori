// telegram-mini-app/ori/main.ori — Todo list for Telegram Mini App.
// The Telegram host calls render() to paint the mini-app and dispatch(ev, arg)
// on user actions. Widget spec lines (chr(10)-separated):
//   text|CONTENT
//   edit|PLACEHOLDER
//   btn|EVENT|ARG|CAPTION          (ARG "@edit" = current input value)
//   item|TOGGLE_EVENT|DEL_EVENT|ARG|CAPTION

hold todos = []    // each element is [doneFlag, label]

fold render {
    hold s = ""
    s = s + "text|Ori Todo — Telegram" + chr 10
    s = s + "text|Same Ori logic, running inside Telegram" + chr 10
    s = s + "edit|What needs doing?" + chr 10
    s = s + "btn|add|@edit|Add" + chr 10
    hold i = 0
    loop i < len todos {
        hold it   = todos[i]
        hold mark = "[ ] "
        when it[0] == 1 { mark = "[x] " }
        s = s + "item|toggle|del|" + str i + "|" + mark + it[1] + chr 10
        i = i + 1
    }
    give s
}

fold dispatch ev arg {
    when ev == "add" {
        when len arg > 0 { push (todos, [0, arg]) }
    } else when ev == "toggle" {
        hold idx = num arg
        when idx >= 0 && idx < len todos {
            hold it = todos[idx]
            when it[0] == 0 { it[0] = 1 } else { it[0] = 0 }
        }
    } else when ev == "del" {
        hold idx = num arg
        hold kept = []
        hold i = 0
        loop i < len todos {
            when i != idx { push (kept, todos[i]) }
            i = i + 1
        }
        todos = kept
    }
    give render()
}

// Pre-loaded sample todos
push (todos, [0, "Build the Ori compiler"])
push (todos, [0, "Ship to every platform"])
