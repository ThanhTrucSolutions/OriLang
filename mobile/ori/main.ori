// mobile/ori/main.ori — the Ori program bundled into the Android APK.
// It runs on the native C VM (libori.so) via JNI; output shows in the app.

fold fib n {
    when n < 2 { give n }
    give fib (n - 1) + fib (n - 2)
}

say "Ori VM running on Android!"
say "(the same C VM as desktop, cross-compiled to native code)"
say ""
hold i = 0
loop i < 15 {
    say ("fib " + str i + " = " + str (fib i))
    i = i + 1
}
