// main.ori — a native Ori console app (no parentheses for calls).
// Run with:  ori run app    (or  ori dev app  for hot reload)

fold fib n {
    when n < 2 { give n }
    give fib (n - 1) + fib (n - 2)
}

fold fact n {
    when n <= 1 { give 1 }
    give n * fact (n - 1)
}

say "== Ori app =="

hold i = 0
loop i < 10 {
    say ("fib(" + str i + ") = " + str (fib i))
    i = i + 1
}

say ("5! = " + str (fact 5))
say "Built by Ori, run on the C VM."
