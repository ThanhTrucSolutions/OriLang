// ============================================================================
//  oric.ori — the Ori compiler, written in Ori (self-hosting).
//
//  Reads an .ori source file and writes a .orb bytecode image that the C core
//  VM (core/orivm.c) runs. This compiler is rich enough to compile *itself*:
//  it supports hold, fold/give (recursion), when/else/else-when, loop,
//  arithmetic, comparisons, unary - / !, logical && / || (short-circuit),
//  calls, strings (with \" \\ \n \t escapes), integers, yes/no/none, and
//  arrays ([..], indexing a[i], index assignment a[i] = v).
//
//  Usage (on the C VM):   orivm oric.orb  <source.ori>  <out.orb>
// ============================================================================

// ---- token kinds ----
hold TK_NUM = 0
hold TK_STR = 1
hold TK_IDENT = 2
hold TK_SYM = 3
hold TK_EOF = 4
hold TK_NL = 5      // newline = statement terminator (with continuation rules)

// ---- AST node tags ----
hold N_NUM = 0
hold N_STR = 1
hold N_VAR = 2
hold N_BIN = 3
hold N_UNARY = 4
hold N_ASSIGN = 5
hold N_CALL = 6
hold N_HOLD = 7
hold N_WHEN = 8
hold N_LOOP = 9
hold N_GIVE = 10
hold N_EXPR = 11
hold N_FOLD = 12
hold N_BOOL = 13
hold N_NIL = 14
hold N_ARRAY = 15
hold N_INDEX = 16
hold N_INDEXSET = 17
hold N_LOGICAL = 18

// ---- VM opcodes (must match core/orivm.c) ----
hold OP_PUSHCONST = 1
hold OP_PUSHNIL = 2
hold OP_PUSHTRUE = 3
hold OP_PUSHFALSE = 4
hold OP_POP = 5
hold OP_LOADGLOBAL = 6
hold OP_STOREGLOBAL = 7
hold OP_LOADLOCAL = 8
hold OP_STORELOCAL = 9
hold OP_NEG = 15
hold OP_NOT = 22
hold OP_JMP = 23
hold OP_JMPIFFALSE = 24
hold OP_JMPIFTRUE = 25
hold OP_CALL = 26
hold OP_RET = 27
hold OP_MAKEARRAY = 28
hold OP_INDEX = 29
hold OP_STOREINDEX = 30
hold OP_PUSHINT = 31

// ---- parser/codegen state ----
hold P_toks = []
hold P_pos = 0
hold C_kinds = []
hold C_vals = []
hold F_names = []
hold F_arity = []
hold F_local = []
hold F_code = []
hold CUR_CODE = []
hold CUR_LNAMES = []
hold CUR_LSLOTS = []
hold CUR_NEXTSLOT = 0
hold CUR_ISMAIN = no
hold LAST_KIND = 0 - 1   // tokenizer: kind of last emitted token
hold LAST_TEXT = ""
hold DEPTH = 0           // ( and [ nesting depth (newlines suppressed inside)
hold P_FNAMES = []
hold P_FARITY = []

// ---------------------------------------------------------------------------
//  Character helpers + tokenizer
// ---------------------------------------------------------------------------
fold is_digit(c) {
    hold k = ord(c)
    give k >= 48 && k <= 57
}
fold is_alpha(c) {
    hold k = ord(c)
    give (k >= 65 && k <= 90) || (k >= 97 && k <= 122) || c == "_"
}
fold is_ident(c) {
    give is_alpha(c) || is_digit(c)
}
fold is_space(c) {
    give c == " " || c == chr(9) || c == chr(10) || c == chr(13)
}

fold emit_tok(toks, kind, text, n) {
    push(toks, [kind, text, n])
    LAST_KIND = kind
    LAST_TEXT = text
    when kind == TK_SYM {
        when text == "(" || text == "[" { DEPTH = DEPTH + 1 }
        when text == ")" || text == "]" { DEPTH = DEPTH - 1 }
    }
}

// Should a newline be suppressed (treated as a line continuation, not a terminator)?
fold nl_is_continuation() {
    when LAST_KIND == TK_NL { give yes }
    when LAST_KIND == 0 - 1 { give yes }
    when LAST_KIND == TK_SYM {
        hold t = LAST_TEXT
        give t == "+" || t == "-" || t == "*" || t == "/" || t == "%" || t == "==" || t == "!=" || t == "<" || t == ">" || t == "<=" || t == ">=" || t == "&&" || t == "||" || t == "=" || t == "!" || t == "(" || t == "[" || t == "{" || t == ","
    }
    give no
}

fold tokenize(src) {
    hold toks = []
    hold n = len(src)
    hold i = 0
    LAST_KIND = 0 - 1
    LAST_TEXT = ""
    DEPTH = 0
    loop i < n {
        hold c = char_at(src, i)
        when c == chr(10) {
            hold suppress = DEPTH > 0
            when !suppress {
                when nl_is_continuation() { suppress = yes }
            }
            when !suppress { emit_tok(toks, TK_NL, "", 0) }
            i = i + 1
        } else when is_space(c) {
            i = i + 1
        } else when c == "/" && char_at(src, i + 1) == "/" {
            loop i < n && char_at(src, i) != chr(10) {
                i = i + 1
            }
        } else when is_digit(c) {
            hold s0 = i
            loop i < n && is_digit(char_at(src, i)) {
                i = i + 1
            }
            when char_at(src, i) == "." && is_digit(char_at(src, i + 1)) {
                i = i + 1
                loop i < n && is_digit(char_at(src, i)) {
                    i = i + 1
                }
            }
            hold numtext = substr(src, s0, i - s0)
            emit_tok(toks, TK_NUM, numtext, num(numtext))
        } else when is_alpha(c) {
            hold s1 = i
            loop i < n && is_ident(char_at(src, i)) {
                i = i + 1
            }
            emit_tok(toks, TK_IDENT, substr(src, s1, i - s1), 0)
        } else when c == "\"" {
            i = i + 1
            hold sval = ""
            loop i < n && char_at(src, i) != "\"" {
                hold ch = char_at(src, i)
                when ch == "\\" {
                    i = i + 1
                    hold e = char_at(src, i)
                    when e == "n" { sval = sval + chr(10) }
                    else when e == "t" { sval = sval + chr(9) }
                    else when e == "r" { sval = sval + chr(13) }
                    else { sval = sval + e }
                    i = i + 1
                } else {
                    sval = sval + ch
                    i = i + 1
                }
            }
            i = i + 1
            emit_tok(toks, TK_STR, sval, 0)
        } else {
            hold two = substr(src, i, 2)
            when two == "==" || two == "!=" || two == "<=" || two == ">=" || two == "&&" || two == "||" {
                emit_tok(toks, TK_SYM, two, 0)
                i = i + 2
            } else {
                emit_tok(toks, TK_SYM, substr(src, i, 1), 0)
                i = i + 1
            }
        }
    }
    emit_tok(toks, TK_EOF, "", 0)
    give toks
}

// ---------------------------------------------------------------------------
//  Parser
// ---------------------------------------------------------------------------
fold p_kind() { give P_toks[P_pos][0] }
fold p_text() { give P_toks[P_pos][1] }
fold p_num() { give P_toks[P_pos][2] }
fold p_advance() {
    hold t = P_toks[P_pos]
    P_pos = P_pos + 1
    give t
}
fold p_check_sym(s) {
    give p_kind() == TK_SYM && p_text() == s
}
fold p_eat_sym(s) {
    when p_check_sym(s) { give p_advance() }
    say("parse error: expected '" + s + "' but found '" + p_text() + "'")
    give p_advance()
}
fold p_skip_nl() {
    loop p_kind() == TK_NL { p_advance() }
}
fold is_kw(t) {
    give t == "hold" || t == "fold" || t == "when" || t == "loop" || t == "give" || t == "else"
}
fold p_set_arity(name, arity) {
    hold i = 0
    loop i < len(P_FNAMES) {
        when P_FNAMES[i] == name {
            P_FARITY[i] = arity
            give none
        }
        i = i + 1
    }
    push(P_FNAMES, name)
    push(P_FARITY, arity)
}
fold p_get_arity(name) {
    hold i = len(P_FNAMES) - 1
    loop i >= 0 {
        when P_FNAMES[i] == name { give P_FARITY[i] }
        i = i - 1
    }
    give 0 - 1
}
fold p_register_builtins() {
    p_set_arity("say", 1)
    p_set_arity("print", 1)
    p_set_arity("str", 1)
    p_set_arity("num", 1)
    p_set_arity("len", 1)
    p_set_arity("push", 2)
    p_set_arity("pop", 1)
    p_set_arity("char_at", 2)
    p_set_arity("ord", 1)
    p_set_arity("chr", 1)
    p_set_arity("substr", 3)
    p_set_arity("type", 1)
    p_set_arity("abs", 1)
    p_set_arity("floor", 1)
    p_set_arity("sqrt", 1)
    p_set_arity("upper", 1)
    p_set_arity("lower", 1)
    p_set_arity("read_file", 1)
    p_set_arity("write_file", 2)
    p_set_arity("write_bytes", 2)
    p_set_arity("argc", 0)
    p_set_arity("argv", 1)
    p_set_arity("env", 1)
    p_set_arity("exists", 1)
    p_set_arity("sh", 1)
    p_set_arity("mkdirs", 1)
    p_set_arity("copy", 2)
    p_set_arity("abspath", 1)
}
fold starts_arg() {
    hold k = p_kind()
    when k == TK_NUM { give yes }
    when k == TK_STR { give yes }
    when k == TK_IDENT { give !is_kw(p_text()) }
    give no
}

fold parse(src) {
    P_toks = tokenize(src)
    P_pos = 0
    P_FNAMES = []
    P_FARITY = []
    p_register_builtins()
    give parse_program()
}
fold parse_program() {
    hold stmts = []
    p_skip_nl()
    loop p_kind() != TK_EOF {
        push(stmts, parse_stmt())
        p_skip_nl()
    }
    give stmts
}
fold parse_block() {
    p_eat_sym("{")
    hold stmts = []
    p_skip_nl()
    loop !p_check_sym("}") && p_kind() != TK_EOF {
        push(stmts, parse_stmt())
        p_skip_nl()
    }
    p_eat_sym("}")
    give stmts
}
fold parse_stmt() {
    when p_kind() == TK_IDENT {
        hold kw = p_text()
        when kw == "hold" { give parse_hold() }
        when kw == "fold" { give parse_fold() }
        when kw == "when" { give parse_when() }
        when kw == "loop" { give parse_loop() }
        when kw == "give" { give parse_give() }
    }
    give [N_EXPR, parse_expr()]
}
fold parse_hold() {
    p_advance()
    hold name = p_advance()[1]
    p_eat_sym("=")
    give [N_HOLD, name, parse_expr()]
}
fold parse_fold() {
    p_advance()
    hold name = p_advance()[1]
    hold params = []
    when p_check_sym("(") {
        p_advance()
        when !p_check_sym(")") {
            push(params, p_advance()[1])
            loop p_check_sym(",") {
                p_advance()
                push(params, p_advance()[1])
            }
        }
        p_eat_sym(")")
    } else {
        loop p_kind() == TK_IDENT {
            push(params, p_advance()[1])
        }
    }
    p_set_arity(name, len(params))
    give [N_FOLD, name, params, parse_block()]
}
fold parse_when() {
    p_advance()
    hold cond = parse_expr()
    hold thenb = parse_block()
    hold elseb = none
    hold save = P_pos
    p_skip_nl()
    when p_kind() == TK_IDENT && p_text() == "else" {
        p_advance()
        when p_kind() == TK_IDENT && p_text() == "when" {
            elseb = [parse_when()]
        } else {
            elseb = parse_block()
        }
    } else {
        P_pos = save
    }
    give [N_WHEN, cond, thenb, elseb]
}
fold parse_loop() {
    p_advance()
    hold cond = parse_expr()
    give [N_LOOP, cond, parse_block()]
}
fold parse_give() {
    p_advance()
    hold val = none
    when p_kind() != TK_EOF && p_kind() != TK_NL && !p_check_sym("}") {
        val = parse_expr()
    }
    give [N_GIVE, val]
}
fold parse_expr() { give parse_assign() }
fold parse_assign() {
    hold left = parse_or()
    when p_check_sym("=") {
        p_advance()
        hold rhs = parse_assign()
        when left[0] == N_INDEX {
            give [N_INDEXSET, left[1], left[2], rhs]
        }
        give [N_ASSIGN, left[1], rhs]
    }
    give left
}
fold parse_or() {
    hold e = parse_and()
    loop p_check_sym("||") {
        p_advance()
        e = [N_LOGICAL, "||", e, parse_and()]
    }
    give e
}
fold parse_and() {
    hold e = parse_equality()
    loop p_check_sym("&&") {
        p_advance()
        e = [N_LOGICAL, "&&", e, parse_equality()]
    }
    give e
}
fold parse_equality() {
    hold e = parse_comparison()
    loop p_check_sym("==") || p_check_sym("!=") {
        hold op = p_advance()[1]
        e = [N_BIN, op, e, parse_comparison()]
    }
    give e
}
fold parse_comparison() {
    hold e = parse_term()
    loop p_check_sym("<") || p_check_sym(">") || p_check_sym("<=") || p_check_sym(">=") {
        hold op = p_advance()[1]
        e = [N_BIN, op, e, parse_term()]
    }
    give e
}
fold parse_term() {
    hold e = parse_factor()
    loop p_check_sym("+") || p_check_sym("-") {
        hold op = p_advance()[1]
        e = [N_BIN, op, e, parse_factor()]
    }
    give e
}
fold parse_factor() {
    hold e = parse_unary()
    loop p_check_sym("*") || p_check_sym("/") || p_check_sym("%") {
        hold op = p_advance()[1]
        e = [N_BIN, op, e, parse_unary()]
    }
    give e
}
fold parse_unary() {
    when p_check_sym("-") || p_check_sym("!") {
        hold op = p_advance()[1]
        give [N_UNARY, op, parse_unary()]
    }
    give parse_postfix()
}
fold parse_postfix() {
    hold e = parse_primary()
    loop yes {
        when p_check_sym("(") {
            p_advance()
            hold args = []
            when !p_check_sym(")") {
                push(args, parse_expr())
                loop p_check_sym(",") {
                    p_advance()
                    push(args, parse_expr())
                }
            }
            p_eat_sym(")")
            e = [N_CALL, e[1], args]
        } else when p_check_sym("[") {
            p_advance()
            hold idx = parse_expr()
            p_eat_sym("]")
            e = [N_INDEX, e, idx]
        } else when starts_arg() {
            // paren-free application:  f a b   ->   call f with atom args
            hold args = []
            hold arity = 0 - 1
            when e[0] == N_VAR { arity = p_get_arity(e[1]) }
            when arity == 1 {
                push(args, parse_expr())
            } else when arity > 1 {
                hold ai = 0
                loop ai < arity {
                    when ai > 0 && p_check_sym(",") { p_advance() }
                    when ai == arity - 1 {
                        push(args, parse_expr())
                    } else {
                        push(args, parse_unary())
                    }
                    ai = ai + 1
                }
            } else {
                loop starts_arg() {
                    push(args, parse_primary())
                }
            }
            e = [N_CALL, e[1], args]
        } else {
            give e
        }
    }
}
fold parse_primary() {
    when p_kind() == TK_NUM {
        hold v = p_num()
        p_advance()
        give [N_NUM, v]
    }
    when p_kind() == TK_STR {
        hold s = p_text()
        p_advance()
        give [N_STR, s]
    }
    when p_kind() == TK_IDENT {
        hold nm = p_text()
        p_advance()
        when nm == "yes" { give [N_BOOL, 1] }
        when nm == "no" { give [N_BOOL, 0] }
        when nm == "none" { give [N_NIL, 0] }
        give [N_VAR, nm]
    }
    when p_check_sym("(") {
        p_advance()
        hold inner = parse_expr()
        p_eat_sym(")")
        give inner
    }
    when p_check_sym("[") {
        p_advance()
        hold elems = []
        when !p_check_sym("]") {
            push(elems, parse_expr())
            loop p_check_sym(",") {
                p_advance()
                push(elems, parse_expr())
            }
        }
        p_eat_sym("]")
        give [N_ARRAY, elems]
    }
    say("parse error: unexpected token '" + p_text() + "'")
    p_advance()
    give [N_NUM, 0]
}

// ---------------------------------------------------------------------------
//  Code generation
// ---------------------------------------------------------------------------
fold const_str(s) {
    hold i = 0
    loop i < len(C_vals) {
        when C_kinds[i] == 3 && C_vals[i] == s { give i }
        i = i + 1
    }
    push(C_kinds, 3)
    push(C_vals, s)
    give len(C_vals) - 1
}
fold const_num(n) {
    hold i = 0
    loop i < len(C_vals) {
        when C_kinds[i] == 1 && C_vals[i] == n { give i }
        i = i + 1
    }
    push(C_kinds, 1)
    push(C_vals, n)
    give len(C_vals) - 1
}
fold begin_func(isMain) {
    CUR_CODE = []
    CUR_LNAMES = []
    CUR_LSLOTS = []
    CUR_NEXTSLOT = 0
    CUR_ISMAIN = isMain
}
hold CUR_SCOPES = []
fold enter_scope() {
    push(CUR_SCOPES, len(CUR_LNAMES))
}
fold exit_scope() {
    hold mark = pop(CUR_SCOPES)
    loop len(CUR_LNAMES) > mark {
        pop(CUR_LNAMES)
        pop(CUR_LSLOTS)
    }
}
fold emit(op, arg) {
    push(CUR_CODE, [op, arg])
    give len(CUR_CODE) - 1
}
fold here() { give len(CUR_CODE) }
fold patch(at, target) { CUR_CODE[at][1] = target }
fold declare_local(name) {
    hold slot = CUR_NEXTSLOT
    push(CUR_LNAMES, name)
    push(CUR_LSLOTS, slot)
    CUR_NEXTSLOT = CUR_NEXTSLOT + 1
    give slot
}
fold resolve_local(name) {
    // Search from the most recent declaration backwards, so a re-declared name
    // resolves to its latest slot (matching the reference compiler's behavior).
    hold i = len(CUR_LNAMES) - 1
    loop i >= 0 {
        when CUR_LNAMES[i] == name { give CUR_LSLOTS[i] }
        i = i - 1
    }
    give 0 - 1
}
fold binop(op) {
    when op == "+" { give 10 }
    when op == "-" { give 11 }
    when op == "*" { give 12 }
    when op == "/" { give 13 }
    when op == "%" { give 14 }
    when op == "==" { give 16 }
    when op == "!=" { give 17 }
    when op == "<" { give 18 }
    when op == ">" { give 19 }
    when op == "<=" { give 20 }
    when op == ">=" { give 21 }
    say("bad operator " + op)
    give 0
}

fold compile_expr(node) {
    hold nt = node[0]
    when nt == N_NUM {
        hold n = node[1]
        when n == floor(n) && n >= 0 - 2147483648 && n <= 2147483647 {
            emit(OP_PUSHINT, floor(n))
        } else {
            emit(OP_PUSHCONST, const_num(n))
        }
    } else when nt == N_STR {
        emit(OP_PUSHCONST, const_str(node[1]))
    } else when nt == N_BOOL {
        when node[1] == 1 {
            emit(OP_PUSHTRUE, 0)
        } else {
            emit(OP_PUSHFALSE, 0)
        }
    } else when nt == N_NIL {
        emit(OP_PUSHNIL, 0)
    } else when nt == N_VAR {
        hold slot = resolve_local(node[1])
        when slot >= 0 {
            emit(OP_LOADLOCAL, slot)
        } else {
            emit(OP_LOADGLOBAL, const_str(node[1]))
        }
    } else when nt == N_ASSIGN {
        compile_expr(node[2])
        hold name = node[1]
        hold slot = resolve_local(name)
        when slot >= 0 {
            emit(OP_STORELOCAL, slot)
            emit(OP_LOADLOCAL, slot)
        } else {
            hold ci = const_str(name)
            emit(OP_STOREGLOBAL, ci)
            emit(OP_LOADGLOBAL, ci)
        }
    } else when nt == N_INDEX {
        compile_expr(node[1])
        compile_expr(node[2])
        emit(OP_INDEX, 0)
    } else when nt == N_INDEXSET {
        compile_expr(node[1])
        compile_expr(node[2])
        compile_expr(node[3])
        emit(OP_STOREINDEX, 0)
    } else when nt == N_ARRAY {
        hold elems = node[1]
        hold k = 0
        loop k < len(elems) {
            compile_expr(elems[k])
            k = k + 1
        }
        emit(OP_MAKEARRAY, len(elems))
    } else when nt == N_UNARY {
        compile_expr(node[2])
        when node[1] == "-" {
            emit(OP_NEG, 0)
        } else {
            emit(OP_NOT, 0)
        }
    } else when nt == N_LOGICAL {
        compile_expr(node[2])
        when node[1] == "&&" {
            hold jf = emit(OP_JMPIFFALSE, 0)
            compile_expr(node[3])
            hold je = emit(OP_JMP, 0)
            patch(jf, here())
            emit(OP_PUSHFALSE, 0)
            patch(je, here())
        } else {
            hold jt = emit(OP_JMPIFTRUE, 0)
            compile_expr(node[3])
            hold je2 = emit(OP_JMP, 0)
            patch(jt, here())
            emit(OP_PUSHTRUE, 0)
            patch(je2, here())
        }
    } else when nt == N_BIN {
        compile_expr(node[2])
        compile_expr(node[3])
        emit(binop(node[1]), 0)
    } else when nt == N_CALL {
        hold name = node[1]
        hold slot = resolve_local(name)
        when slot >= 0 {
            emit(OP_LOADLOCAL, slot)
        } else {
            emit(OP_LOADGLOBAL, const_str(name))
        }
        hold args = node[2]
        hold k = 0
        loop k < len(args) {
            compile_expr(args[k])
            k = k + 1
        }
        emit(OP_CALL, len(args))
    }
}

fold compile_block(stmts) {
    enter_scope()
    hold k = 0
    loop k < len(stmts) {
        compile_stmt(stmts[k])
        k = k + 1
    }
    exit_scope()
}
fold compile_stmt(node) {
    hold nt = node[0]
    when nt == N_HOLD {
        compile_expr(node[2])
        when CUR_ISMAIN {
            emit(OP_STOREGLOBAL, const_str(node[1]))
        } else {
            hold slot = declare_local(node[1])
            emit(OP_STORELOCAL, slot)
        }
    } else when nt == N_EXPR {
        compile_expr(node[1])
        emit(OP_POP, 0)
    } else when nt == N_GIVE {
        when node[1] != none {
            compile_expr(node[1])
        } else {
            emit(OP_PUSHNIL, 0)
        }
        emit(OP_RET, 0)
    } else when nt == N_WHEN {
        compile_expr(node[1])
        hold jFalse = emit(OP_JMPIFFALSE, 0)
        compile_block(node[2])
        when node[3] != none {
            hold jEnd = emit(OP_JMP, 0)
            patch(jFalse, here())
            compile_block(node[3])
            patch(jEnd, here())
        } else {
            patch(jFalse, here())
        }
    } else when nt == N_LOOP {
        hold start = here()
        compile_expr(node[1])
        hold jExit = emit(OP_JMPIFFALSE, 0)
        compile_block(node[2])
        emit(OP_JMP, start)
        patch(jExit, here())
    }
}

fold compile_program(prog) {
    hold mains = []
    push(F_names, "__main__")
    push(F_arity, 0)
    push(F_local, 0)
    push(F_code, [])
    hold i = 0
    loop i < len(prog) {
        hold st = prog[i]
        when st[0] == N_FOLD {
            push(F_names, st[1])
            push(F_arity, len(st[2]))
            push(F_local, 0)
            push(F_code, [])
        } else {
            push(mains, st)
        }
        i = i + 1
    }
    begin_func(yes)
    compile_block(mains)
    emit(OP_PUSHNIL, 0)
    emit(OP_RET, 0)
    F_code[0] = CUR_CODE
    F_local[0] = CUR_NEXTSLOT
    hold fi = 1
    i = 0
    loop i < len(prog) {
        hold st2 = prog[i]
        when st2[0] == N_FOLD {
            begin_func(no)
            hold ps = st2[2]
            hold k = 0
            loop k < len(ps) {
                declare_local(ps[k])
                k = k + 1
            }
            compile_block(st2[3])
            emit(OP_PUSHNIL, 0)
            emit(OP_RET, 0)
            F_code[fi] = CUR_CODE
            F_local[fi] = CUR_NEXTSLOT
            fi = fi + 1
        }
        i = i + 1
    }
}

// ---------------------------------------------------------------------------
//  Serialize to a .orb byte buffer
// ---------------------------------------------------------------------------
fold emit_u8(buf, b) { push(buf, b % 256) }
fold emit_i32(buf, v) {
    emit_u8(buf, v % 256)
    emit_u8(buf, floor(v / 256) % 256)
    emit_u8(buf, floor(v / 65536) % 256)
    emit_u8(buf, floor(v / 16777216) % 256)
}
fold emit_str(buf, s) {
    emit_i32(buf, len(s))
    hold i = 0
    loop i < len(s) {
        emit_u8(buf, ord(char_at(s, i)))
        i = i + 1
    }
}
fold emit_ascii(buf, s) {
    hold i = 0
    loop i < len(s) {
        emit_u8(buf, ord(char_at(s, i)))
        i = i + 1
    }
}
fold serialize() {
    hold buf = []
    emit_ascii(buf, "ORB1")
    emit_i32(buf, len(C_vals))
    hold i = 0
    loop i < len(C_vals) {
        emit_u8(buf, C_kinds[i])
        when C_kinds[i] == 1 {
            emit_double(buf, C_vals[i])
        } else when C_kinds[i] == 3 {
            emit_str(buf, C_vals[i])
        }
        i = i + 1
    }
    emit_i32(buf, 0)
    emit_i32(buf, len(F_names))
    i = 0
    loop i < len(F_names) {
        emit_str(buf, F_names[i])
        emit_i32(buf, F_arity[i])
        emit_i32(buf, F_local[i])
        hold code = F_code[i]
        emit_i32(buf, len(code))
        hold j = 0
        loop j < len(code) {
            emit_u8(buf, code[j][0])
            emit_i32(buf, code[j][1])
            j = j + 1
        }
        i = i + 1
    }
    give buf
}

// ---------------------------------------------------------------------------
//  Main
// ---------------------------------------------------------------------------
hold src = read_file(argv(0))
hold prog = parse(src)
compile_program(prog)
hold bytes = serialize()
write_bytes(argv(1), bytes)
say("oric.ori: compiled " + argv(0) + " -> " + argv(1) + " (" + str(len(bytes)) + " bytes .orb, " + str(len(F_names)) + " functions)")
